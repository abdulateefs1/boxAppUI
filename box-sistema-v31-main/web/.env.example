# Lokal: Next (3001) → API (3000) uchun (next.config rewrites)
API_TARGET=http://localhost:3000

# Brauzerdan to‘g‘ridan-to‘g‘ri API manzili (odatda bo‘sh — relative /api ishlaydi)
# Boshqa host/port bo‘lsa masalan: NEXT_PUBLIC_API_BASE_URL=https://app.example.com
NEXT_PUBLIC_API_BASE_URL=

# Statik eksport (production, Express web/out bilan):
# build: STATIC_EXPORT=1 npm run build
