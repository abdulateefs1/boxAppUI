# ── ERP integratsiya (Variant A — tavsiya) ─────────────────────────────────
# Zakazlar faqat ERP'da; BoxUI ERP API'dan o'qiydi.
NEXT_PUBLIC_API_SOURCE=erp
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
API_TARGET=http://localhost:3001

# ERP backend ALLOWED_ORIGINS ga qo'shing: http://localhost:3001

